{
  "name": "gw-tournois-bot",
  "version": "1.0.0",
  "description": "Discord bot that automates sign-ups and reminders for Guild Wars Automated Tournaments and Monthly Automated Tournaments.",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "deploy": "node deploy-commands.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "discord.js",
    "guild-wars",
    "tournament",
    "alliance-battle"
  ],
  "author": "taitai42",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taitai42/gwdiscordtournois.git"
  },
  "bugs": {
    "url": "https://github.com/taitai42/gwdiscordtournois/issues"
  },
  "homepage": "https://github.com/taitai42/gwdiscordtournois#readme",
  "dependencies": {
    "discord.js": "^14.14.1",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.1",
    "mysql2": "^3.11.0"
  }
}
