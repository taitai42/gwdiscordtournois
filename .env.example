# --- Discord ---------------------------------------------------------------
# Your Discord bot token (https://discord.com/developers/applications)
DISCORD_TOKEN=your_token_here

# Application ID (from "General Information" in the developer portal)
APPLICATION_ID=your_application_id_here

# --- MySQL -----------------------------------------------------------------
# Used by the `mysql` service in docker-compose AND by the bot.
# Inside docker-compose the bot connects to the host `mysql` (service name).
DB_NAME=gw_tournois
DB_USER=bot
DB_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_too

# --- MySQL (non-Docker deployment) -----------------------------------------
# If you run the bot outside docker-compose, override the host/port here:
# DB_HOST=localhost
# DB_PORT=3306
